  .bolum-text,
  .bolum-img {
    opacity: 0;
  }

  .renk-swatch.active > span:first-child {
    box-shadow: 0 0 0 2px var(--color-accent);
    border-color: var(--color-accent);
  }

  .bolum-bullet {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-muted-3);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .bolum-bullet-active {
    background: var(--color-accent);
    width: 24px;
  }

  .bolum-slider-wrapper .bolum-prev,
  .bolum-slider-wrapper .bolum-next {
    display: none;
  }

  @media (min-width: 768px) {
    .bolum-slider-wrapper .bolum-prev,
    .bolum-slider-wrapper .bolum-next {
      display: flex;
    }
  }
</style>
