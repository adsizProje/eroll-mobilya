---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllOturmaGrubuSlugs, getOturmaGrubuBySlug, getStrapiImageUrl, blocksToHtml, blocksToSummary, getUrunDetayBolumu } from '../../lib/api';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/thumbs';
import 'swiper/css/effect-fade';
import 'swiper/css/pagination';
import 'photoswipe/dist/photoswipe.css';

export async function getStaticPaths() {
  const slugs = await getAllOturmaGrubuSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const product = await getOturmaGrubuBySlug(slug!);

if (!product) {
  return Astro.redirect('/oturma-gruplari');
}

const richContent = product.detayliAciklama ? blocksToHtml(product.detayliAciklama) : '';
const urunDetayBolumu = await getUrunDetayBolumu();

// Prepare images for gallery
const allImages: { id: string; src: string; thumb: string; w: number; h: number; alt: string }[] = [];
if (product.anaGorsel) {
    allImages.push({
        id: 'hero',
        src: getStrapiImageUrl(product.anaGorsel, 'large'),
        thumb: getStrapiImageUrl(product.anaGorsel, 'thumbnail'),
        w: product.anaGorsel.width || 1200,
        h: product.anaGorsel.height || 900,
        alt: product.baslik
    });
}
if (product.galeriGorselleri) {
    product.galeriGorselleri.forEach((img, idx) => {
        allImages.push({
            id: `gallery-${idx}`,
            src: getStrapiImageUrl(img, 'large'),
            thumb: getStrapiImageUrl(img, 'thumbnail'),
            w: img.width || 1200,
            h: img.height || 900,
            alt: `${product.baslik} - ${idx + 1}`
        });
    });
}

const summary = blocksToSummary(product.detayliAciklama);
const seoDescription = summary
  ? `${product.baslik} - ${summary} | Eroll Mobilya Elazig`
  : `${product.baslik} - Eroll Mobilya tarafından özenle üretilen kaliteli oturma grubu. Elazığ mobilya imalatı.`;

// Renk varyantlari
const renkVaryantlari = product.renkVaryantlari || [];

// Alt bolum gorselleri
const bolumGorselleri = urunDetayBolumu?.bolumGorselleri || [];
---

<BaseLayout title={`${product.baslik} | Eroll Mobilya & Koltuk`} description={seoDescription}>
  <!-- Mobile Sticky Bottom Bar -->
  <div class="fixed bottom-0 left-0 right-0 z-50 bg-bg border-t border-muted-3 p-3 md:hidden flex gap-3 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
    <a
      href={`https://wa.me/905301227623?text=${encodeURIComponent(`Merhaba, ${product.baslik} hakkında bilgi almak istiyorum.`)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="flex-1 px-4 py-3 bg-[#25D366] text-white font-semibold rounded-xl hover:bg-[#128C7E] transition-colors flex items-center justify-center gap-2 text-sm shadow-sm"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
    <a
      href="tel:+905301227623"
      class="flex-1 px-4 py-3 bg-fg text-bg font-semibold rounded-xl hover:bg-fg/90 transition-colors flex items-center justify-center gap-2 text-sm shadow-sm"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      Hemen Ara
    </a>
  </div>

  <div class="max-w-[1600px] mx-auto px-0 md:px-6 lg:px-8 py-0 md:py-4 lg:py-6 pb-24 md:pb-8">
    <!-- Breadcrumb -->
    <nav class="hidden md:block py-4 px-4 mb-4">
      <ol class="flex items-center gap-2 text-sm">
        <li>
          <a href="/" class="text-fg-muted hover:text-accent transition-colors">Ana Sayfa</a>
        </li>
        <li class="text-fg-muted">/</li>
        <li>
          <a href="/oturma-gruplari" class="text-fg-muted hover:text-accent transition-colors">Oturma Grupları</a>
        </li>
        <li class="text-fg-muted">/</li>
        <li class="text-accent font-medium">{product.baslik}</li>
      </ol>
    </nav>

    <div class="grid lg:grid-cols-[1.4fr_0.8fr] gap-0 lg:gap-12 xl:gap-16 items-start">
        <!-- Gallery Section -->
        <div class="product-gallery relative group bg-bg-alt md:rounded-2xl overflow-hidden">
            {allImages.length > 0 ? (
                <div class="relative select-none">
                    <!-- Main Swiper -->
                    <div class="swiper main-swiper w-full aspect-4/3 md:aspect-16/10 bg-muted-3 md:rounded-2xl overflow-hidden">
                        <div class="swiper-wrapper">
                            {allImages.map((img) => (
                                <div class="swiper-slide cursor-zoom-in">
                                    <a
                                        href={img.src}
                                        data-pswp-width={img.w}
                                        data-pswp-height={img.h}
                                        target="_blank"
                                        rel="noreferrer"
                                        class="block w-full h-full pswp-link"
                                    >
                                        <img
                                            src={img.src}
                                            alt={img.alt}
                                            class="w-full h-full object-contain"
                                        />
                                    </a>
                                </div>
                            ))}
                        </div>
                        <div class="swiper-button-next text-white! w-10! h-10! bg-black/30! hover:bg-black/50! backdrop-blur-sm! rounded-full! transition-colors flex items-center justify-center after:content-none!">
                            <svg class="w-6 h-6 transform scale-[0.6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </div>
                        <div class="swiper-button-prev text-white! w-10! h-10! bg-black/30! hover:bg-black/50! backdrop-blur-sm! rounded-full! transition-colors flex items-center justify-center after:content-none!">
                            <svg class="w-6 h-6 transform scale-[0.6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </div>
                    </div>

                    <!-- Thumbnails Swiper -->
                     {allImages.length > 1 && (
                        <div class="hidden md:block p-4">
                            <div class="swiper thumbs-swiper mt-0 py-1! px-2!">
                                <div class="swiper-wrapper">
                                    {allImages.map((img) => (
                                        <div class="swiper-slide !w-20 aspect-square rounded-lg overflow-hidden cursor-pointer opacity-50 transition-all duration-300 hover:opacity-100 [&.swiper-slide-thumb-active]:opacity-100 [&.swiper-slide-thumb-active]:ring-2 [&.swiper-slide-thumb-active]:ring-accent [&.swiper-slide-thumb-active]:scale-105">
                                            <img
                                                src={img.thumb}
                                                alt={img.alt}
                                                class="w-full h-full object-cover"
                                            />
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>
                     )}

                     <!-- Mobile Pagination Indicator -->
                     <div class="absolute bottom-2 right-2 z-20 md:hidden bg-black/50 backdrop-blur-sm px-2 py-1 rounded-full text-white text-sm font-medium">
                        <span class="current-slide">1</span> / <span class="total-slides">{allImages.length}</span>
                     </div>
                </div>
            ) : (
                <div class="aspect-video w-full flex items-center justify-center text-fg-muted bg-muted-3 rounded-2xl">
                    <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>
            )}
        </div>

        <!-- Product Details Section -->
        <div class="px-4 py-6 md:p-0 md:sticky md:top-8 h-fit space-y-8">
            <div class="space-y-4">
                <nav class="md:hidden">
                     <ol class="flex items-center gap-2 text-xs text-fg-muted mb-2">
                        <li><a href="/oturma-gruplari">Oturma Grupları</a></li>
                        <li>/</li>
                        <li class="font-medium text-fg">{product.baslik}</li>
                    </ol>
                </nav>
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-fg leading-tight">{product.baslik}</h1>
            </div>

            <!-- Renk Varyantlari -->
            {renkVaryantlari.length > 0 && (
                <div class="space-y-3">
                    <span class="text-xs font-semibold text-fg-muted uppercase tracking-wider">Renk Seçenekleri</span>
                    <div class="flex flex-wrap gap-3">
                        {renkVaryantlari.map((renk) => (
                            <button
                                class="renk-swatch group relative flex flex-col items-center gap-1"
                                data-slide-index={renk.resimSirasi ?? 0}
                                title={renk.renkAdi}
                            >
                                {renk.renkKodu ? (
                                    <span
                                        class="w-14 h-14 rounded-lg border-2 border-muted-3 hover:ring-2 hover:ring-accent transition-all cursor-pointer"
                                        style={`background-color: ${renk.renkKodu};`}
                                    ></span>
                                ) : renk.gorsel ? (
                                    <span class="w-14 h-14 rounded-lg border-2 border-muted-3 hover:ring-2 hover:ring-accent transition-all cursor-pointer overflow-hidden">
                                        <img src={getStrapiImageUrl(renk.gorsel, 'thumbnail')} alt={renk.renkAdi} class="w-full h-full object-cover" />
                                    </span>
                                ) : (
                                    <span class="w-14 h-14 rounded-lg border-2 border-muted-3 bg-muted-3 hover:ring-2 hover:ring-accent transition-all cursor-pointer"></span>
                                )}
                                <span class="text-xs text-fg-muted">{renk.renkAdi}</span>
                            </button>
                        ))}
                    </div>
                </div>
            )}

            <!-- Desktop Actions -->
            <div class="hidden md:flex flex-col gap-3">
                 <a
                  href={`https://wa.me/905301227623?text=${encodeURIComponent(`Merhaba, ${product.baslik} hakkında bilgi almak istiyorum.`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full px-6 py-4 bg-[#25D366] text-white text-lg font-bold rounded-xl hover:bg-[#128C7E] flex items-center justify-center gap-3 shadow-lg shadow-[#25D366]/20 hover:shadow-xl hover:shadow-[#25D366]/30 transform hover:-translate-y-0.5 transition-all"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp ile Bilgi Al
                </a>
                <a
                  href="tel:+905301227623"
                  class="w-full px-6 py-4 border-2 border-fg font-bold rounded-xl hover:bg-fg hover:text-bg transition-colors flex items-center justify-center gap-3"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  Hemen Ara
                </a>
            </div>

            <!-- Description/Rich Content -->
            {richContent && (
                <div class="prose-content pt-4 border-t border-muted-3" set:html={richContent} />
            )}
        </div>
    </div>

    <!-- Alt Tanıtım Bölümü (Global) -->
    {urunDetayBolumu && (urunDetayBolumu.bolumBaslik || bolumGorselleri.length > 0) && (
      <section class="bolum-section mt-16 py-16 border-t border-muted-3">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="bolum-text text-center max-w-2xl mx-auto mb-10 space-y-4">
            {urunDetayBolumu.bolumBaslik && (
              <h2 class="text-3xl md:text-4xl font-bold">{urunDetayBolumu.bolumBaslik}</h2>
            )}
            {urunDetayBolumu.bolumAciklama && (
              <p class="text-fg-muted leading-relaxed text-lg">{urunDetayBolumu.bolumAciklama}</p>
            )}
          </div>
            {bolumGorselleri.length > 0 && (
              <div class="bolum-slider-wrapper relative">
                <div class="swiper bolum-swiper rounded-2xl overflow-hidden">
                  <div class="swiper-wrapper">
                    {bolumGorselleri.map((img, idx) => (
                      <div class="swiper-slide">
                        <div class="bolum-img aspect-[4/3] rounded-2xl overflow-hidden">
                          <img
                            src={getStrapiImageUrl(img, 'medium')}
                            alt={img.alternativeText || `Görsel ${idx + 1}`}
                            class="w-full h-full object-cover"
                            loading="lazy"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                <!-- Navigation -->
                <button class="bolum-prev absolute left-[-20px] top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-bg border border-muted-3 rounded-full shadow-lg flex items-center justify-center hover:bg-accent hover:text-white hover:border-accent transition-all">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <button class="bolum-next absolute right-[-20px] top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-bg border border-muted-3 rounded-full shadow-lg flex items-center justify-center hover:bg-accent hover:text-white hover:border-accent transition-all">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
                <!-- Pagination dots -->
                <div class="bolum-pagination flex justify-center gap-2 mt-4"></div>
              </div>
            )}
        </div>
      </section>
    )}
  </div>

  <!-- SEO Text Block -->
  <section class="py-12 border-t border-muted-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-semibold mb-3 text-fg">{product.baslik} - Eroll Mobilya</h2>
      <p class="text-sm text-fg-muted/70 leading-relaxed">
        {product.baslik}, Eroll Mobilya tarafından özenle üretilen kaliteli bir oturma grubudur. Elazığ mobilya imalatı alanında uzman kadromuz tarafından, en kaliteli malzemeler kullanılarak hazırlanmıştır. {summary ? summary : `Modern tasarımı ve dayanıklı yapısıyla yaşam alanlarınıza değer katan ${product.baslik}, koltuk takımı ve salon takımı arayanlar için ideal bir seçimdir.`} Özel sipariş ve kişiselleştirilmiş tasarımlar için bizimle iletişime geçebilirsiniz.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Prose Content Styling */
  .prose-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-fg);
  }

  .prose-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-fg);
  }

  .prose-content p {
    color: var(--color-fg-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .prose-content ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
    list-style-type: disc;
  }

  .prose-content li {
    margin-bottom: 0.5rem;
    color: var(--color-fg-muted);
  }

  .prose-content img {
    border-radius: 1rem;
    margin: 1.5rem 0;
    width: 100%;
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Navigation, Thumbs, EffectFade, Keyboard, Pagination, Autoplay } from 'swiper/modules';
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import PhotoSwipe from 'photoswipe';

  function initGallery() {
    if (!document.querySelector('.product-gallery')) return;

    // Initialize Thumbs Swiper
    const thumbsSwiper = new Swiper('.thumbs-swiper', {
      modules: [Navigation, Thumbs],
      spaceBetween: 10,
      slidesPerView: 4,
      freeMode: true,
      watchSlidesProgress: true,
      centerInsufficientSlides: true,
      breakpoints: {
        640: {
            slidesPerView: 5,
        },
        1024: {
            slidesPerView: 6,
        }
      }
    });

    // Initialize Main Swiper
    const mainSwiper = new Swiper('.main-swiper', {
      modules: [Navigation, Thumbs, EffectFade, Keyboard],
      spaceBetween: 0,
      slidesPerView: 1,
      effect: 'fade',
      loop: true,
      preventClicks: false,
      preventClicksPropagation: false,
      fadeEffect: {
        crossFade: true
      },
      keyboard: {
        enabled: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      thumbs: {
        swiper: thumbsSwiper,
      },
      on: {
        slideChange: (swiper) => {
            const current = swiper.realIndex + 1;
            const currentEl = document.querySelector('.current-slide');
            if (currentEl) currentEl.textContent = current.toString();
        }
      }
    });

    // Initialize PhotoSwipe for main gallery
    const lightbox = new PhotoSwipeLightbox({
      gallery: '.main-swiper .swiper-wrapper',
      children: '.swiper-slide:not(.swiper-slide-duplicate) .pswp-link',
      pswpModule: PhotoSwipe,
      padding: { top: 20, bottom: 20, left: 20, right: 20 },
    });

    // Prevent Swiper from blocking clicks on zoom links
    lightbox.addFilter('isClickableElement', (isClickable, el) => {
      if (el.closest('.pswp-link')) return true;
      return isClickable;
    });

    lightbox.init();

    // Boyut gorseli zoom
    const boyutZoomLink = document.querySelector('.boyut-zoom-link');
    if (boyutZoomLink) {
      const boyutLightbox = new PhotoSwipeLightbox({
        gallery: '.boyut-zoom-link',
        pswpModule: PhotoSwipe,
        padding: { top: 20, bottom: 20, left: 20, right: 20 },
      });
      // PhotoSwipe needs an anchor with data-pswp-width/height
      boyutLightbox.init();
    }

    // Renk varyanti swatch click -> slide gallery to that index
    const renkSwatches = document.querySelectorAll('.renk-swatch');
    renkSwatches.forEach((swatch) => {
      swatch.addEventListener('click', () => {
        const slideIndex = parseInt((swatch as HTMLElement).dataset.slideIndex || '0');

        // Slide to the corresponding gallery image
        mainSwiper.slideToLoop(slideIndex, 500);

        // Update active state on swatches
        renkSwatches.forEach((s) => s.classList.remove('active'));
        swatch.classList.add('active');
      });
    });
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }

  // Also run on Astro page load
  document.addEventListener('astro:page-load', initGallery);

  // Initialize Bolum Swiper (autoplay sadece viewport'a girince başlar)
  function initBolumSwiper() {
    const bolumEl = document.querySelector('.bolum-swiper');
    const bolumSection = document.querySelector('.bolum-section');
    if (!bolumEl || !bolumSection) return;

    const swiper = new Swiper('.bolum-swiper', {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1.2,
      spaceBetween: 12,
      loop: true,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: '.bolum-next',
        prevEl: '.bolum-prev',
      },
      pagination: {
        el: '.bolum-pagination',
        clickable: true,
        bulletClass: 'bolum-bullet',
        bulletActiveClass: 'bolum-bullet-active',
      },
      breakpoints: {
        480: {
          slidesPerView: 1.5,
          spaceBetween: 16,
        },
        640: {
          slidesPerView: 2,
          spaceBetween: 16,
        },
        1024: {
          slidesPerView: 2.5,
          spaceBetween: 20,
        },
      },
    });

    // Autoplay sadece bolum-section viewport'a girince başlar
    swiper.autoplay.stop();
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            swiper.autoplay.start();
          } else {
            swiper.autoplay.stop();
          }
        });
      },
      { threshold: 0.2 }
    );
    io.observe(bolumSection);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBolumSwiper);
  } else {
    initBolumSwiper();
  }
  document.addEventListener('astro:page-load', initBolumSwiper);

  // Bolum section animation
  import { animate, inView, stagger } from "motion";

  inView('.bolum-section', (info) => {
    const target = info.target || info;
    const text = target.querySelector('.bolum-text');
    const imgs = target.querySelectorAll('.bolum-img');

    if (text) {
      animate(text, { opacity: [0, 1], x: [-30, 0] }, { duration: 0.8, ease: 'easeOut' });
    }
    if (imgs.length > 0) {
      animate(imgs, { opacity: [0, 1], y: [30, 0] }, {
        duration: 0.7,
        delay: stagger(0.15, { startDelay: 0.2 }),
        ease: [0.22, 1, 0.36, 1]
      });
    }
  }, { amount: 0.2 });
</script>

