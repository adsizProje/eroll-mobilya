---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getOturmaGruplari, getAnasaydaUrunleri, getAnasayfaAyarlari, getStrapiImageUrl, blocksToSummary } from "../lib/api";

// Build time'da oturma gruplarini cek
const oturmaGruplari = await getOturmaGruplari();

// Anasayfada gosterilecek urunler (tikli olanlar, yoksa ilk 4)
const anasaydaUrunleri = await getAnasaydaUrunleri();
const featuredProducts = anasaydaUrunleri.length > 0 ? anasaydaUrunleri : oturmaGruplari.slice(0, 4);

// Hero fotograflari icin anaGorsel'i olan urunler
const heroUrunler = oturmaGruplari.filter(p => p.anaGorsel);

// Anasayfa ayarlari
const anasayfaAyarlari = await getAnasayfaAyarlari();
const bolumGorselleri = anasayfaAyarlari?.bolumGorselleri || [];
---

<BaseLayout title="Eroll Mobilya & Koltuk | Elazığ Mobilya İmalatı, Oturma Grubu ve Koltuk Takımı" description="Eroll Mobilya & Koltuk - Elazığ'da kaliteli mobilya imalatı, oturma grubu, koltuk takımı ve salon takımı. Toptan ve perakende satış. Özel tasarım mobilya siparişi.">
  <!-- Hero Section -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-linear-to-br from-bg via-bg-alt to-muted-3">
    </div>
    <div
      class="absolute inset-0 opacity-5"
      style="background-image: url('/pattern.svg');"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 md:py-4">
      <div class="grid lg:grid-cols-2 lg:gap-12 gap-6 items-center">
        <div class="hero-content space-y-8">
          <div
            class="hero-badge inline-flex items-center gap-2 px-4 py-2 bg-accent/10 rounded-full"
          >
            <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
            <span class="text-sm font-medium text-accent-dark"
              >İmalat &bull; Toptan &bull; Perakende</span
            >
          </div>

          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-balance"
          >
            Evinize
            <span
              class="text-accent inline-flex flex-col h-[1.35em] overflow-hidden align-middle -mt-1"
            >
              <span class="word-rotator *:block" style="will-change: transform;">
                <span>Zarafet</span>
                <span>Şıklık</span>
                <span>Konfor</span>
                <span>Estetik</span>
                <span>Kalite</span>
                <span>Prestij</span>
                <span>Huzur</span>
                <span>Zarafet</span>
                <!-- Duplicate first for smooth loop -->
              </span>
            </span>
            Katıyoruz
          </h1>

          <p class="text-lg text-fg-muted max-w-lg">
            Kaliteli işçilik ve özenli tasarımlarla ürettiğimiz mobilya ve
            koltuklarla yaşam alanlarınızı güzelleştiriyoruz.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="/oturma-gruplari"
              class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-dark transition-all shadow-[0_4px_20px_rgba(10,9,8,0.08),0_2px_8px_rgba(10,9,8,0.04)] hover:shadow-[0_8px_40px_rgba(10,9,8,0.12),0_4px_16px_rgba(10,9,8,0.06)]"
            >
              Ürünleri İncele
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/iletisim"
              class="inline-flex items-center gap-2 px-6 py-3 border-2 border-fg text-fg font-semibold rounded-lg hover:bg-fg hover:text-bg transition-all"
            >
              İletişime Geç
            </a>
          </div>
        </div>

        <div
          class="hero-gallery relative mt-8 lg:mt-0 h-[450px] lg:h-[600px] overflow-hidden -mx-4 sm:mx-0 max-md:px-2"
        >
          <div
            class="absolute top-0 left-0 right-0 h-9 bg-linear-to-b from-bg/50 to-transparent z-10 pointer-events-none"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 right-0 h-9 bg-linear-to-t from-bg/50 to-transparent z-10 pointer-events-none"
          >
          </div>

          <div class="grid grid-cols-2 gap-4 lg:gap-6 h-full">
            <!-- Column 1 -->
            <div class="flex flex-col gap-4 lg:gap-6 animate-scroll-vertical">
              {heroUrunler.length > 0 ? (
                <>
                  {heroUrunler.map((product, i) => (
                    <a href={`/oturma-gruplari/${product.slug}`} class="relative block group shrink-0">
                      <img
                        src={getStrapiImageUrl(product.anaGorsel, "medium")}
                        class={`w-full ${i % 3 === 0 ? 'h-64' : i % 3 === 1 ? 'h-80' : 'h-72'} object-cover rounded-2xl shadow-lg`}
                        alt={product.baslik}
                      />
                      <div class="hero-overlay absolute inset-0 bg-linear-to-t from-black/60 via-black/0 to-transparent md:from-black/80 md:via-black/20 rounded-2xl flex items-end p-4 opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                        <div class="text-white">
                          <span class="text-sm font-light leading-tight block">{product.baslik}</span>
                          <span class="text-xs font-light opacity-70 flex items-center gap-1 mt-0.5">
                            Ürünü İncele
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                  {/* Duplicate for infinite scroll */}
                  {heroUrunler.map((product, i) => (
                    <a href={`/oturma-gruplari/${product.slug}`} class="relative block group shrink-0">
                      <img
                        src={getStrapiImageUrl(product.anaGorsel, "medium")}
                        class={`w-full ${i % 3 === 0 ? 'h-64' : i % 3 === 1 ? 'h-80' : 'h-72'} object-cover rounded-2xl shadow-lg`}
                        alt={product.baslik}
                      />
                      <div class="hero-overlay absolute inset-0 bg-linear-to-t from-black/60 via-black/0 to-transparent md:from-black/80 md:via-black/20 rounded-2xl flex items-end p-4 opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                        <div class="text-white">
                          <span class="text-sm font-light leading-tight block">{product.baslik}</span>
                          <span class="text-xs font-light opacity-70 flex items-center gap-1 mt-0.5">
                            Ürünü İncele
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </>
              ) : (
                <>
                  <img src="/hero1.jpg" class="w-full h-64 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero2.jpg" class="w-full h-80 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero3.jpg" class="w-full h-64 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero1.jpg" class="w-full h-64 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero2.jpg" class="w-full h-80 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero3.jpg" class="w-full h-64 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                </>
              )}
            </div>

            <!-- Column 2 - Slower Scroll -->
            <div
              class="flex flex-col gap-4 lg:gap-6 animate-scroll-vertical"
              style="animation-duration: 35s; transform: translateY(-30%);"
            >
              {heroUrunler.length > 0 ? (
                <>
                  {[...heroUrunler].reverse().map((product, i) => (
                    <a href={`/oturma-gruplari/${product.slug}`} class="relative block group shrink-0">
                      <img
                        src={getStrapiImageUrl(product.anaGorsel, "medium")}
                        class={`w-full ${i % 3 === 0 ? 'h-72' : i % 3 === 1 ? 'h-64' : 'h-80'} object-cover rounded-2xl shadow-lg`}
                        alt={product.baslik}
                      />
                      <div class="hero-overlay absolute inset-0 bg-linear-to-t from-black/60 via-black/0 to-transparent md:from-black/80 md:via-black/20 rounded-2xl flex items-end p-4 opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                        <div class="text-white">
                          <span class="text-sm font-light leading-tight block">{product.baslik}</span>
                          <span class="text-xs font-light opacity-70 flex items-center gap-1 mt-0.5">
                            Ürünü İncele
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                  {[...heroUrunler].reverse().map((product, i) => (
                    <a href={`/oturma-gruplari/${product.slug}`} class="relative block group shrink-0">
                      <img
                        src={getStrapiImageUrl(product.anaGorsel, "medium")}
                        class={`w-full ${i % 3 === 0 ? 'h-72' : i % 3 === 1 ? 'h-64' : 'h-80'} object-cover rounded-2xl shadow-lg`}
                        alt={product.baslik}
                      />
                      <div class="hero-overlay absolute inset-0 bg-linear-to-t from-black/60 via-black/0 to-transparent md:from-black/80 md:via-black/20 rounded-2xl flex items-end p-4 opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                        <div class="text-white">
                          <span class="text-sm font-light leading-tight block">{product.baslik}</span>
                          <span class="text-xs font-light opacity-70 flex items-center gap-1 mt-0.5">
                            Ürünü İncele
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </>
              ) : (
                <>
                  <img src="/hero2.jpg" class="w-full h-72 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero3.jpg" class="w-full h-64 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero1.jpg" class="w-full h-80 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero2.jpg" class="w-full h-72 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero3.jpg" class="w-full h-64 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                  <img src="/hero1.jpg" class="w-full h-80 object-cover rounded-2xl shadow-lg" alt="Mobilya" />
                </>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services-section py-20 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="services-title text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Hizmetlerimiz</h2>
        <p class="text-fg-muted max-w-2xl mx-auto">
          Mobilya sektöründe kaliteyi ön planda tutarak sizlere en iyi hizmeti
          sunuyoruz.
        </p>
      </div>

      {/* Mobile: Swiper */}
      <div class="services-swiper-container block md:hidden">
        <div class="swiper services-swiper">
          <div class="swiper-wrapper">
            <div class="swiper-slide">
              <div class="service-card bg-bg-alt p-8 rounded-2xl border border-muted-3">
                <div class="service-icon w-16 h-16 flex items-center justify-center bg-accent/10 text-accent rounded-xl mb-4">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">İmalat</h3>
                <p class="text-fg-muted">Kendi atölyemizde özenle üretilen, kaliteli malzemelerle hazırlanan mobilyalar.</p>
              </div>
            </div>
            <div class="swiper-slide">
              <div class="service-card bg-bg-alt p-8 rounded-2xl border border-muted-3">
                <div class="service-icon w-16 h-16 flex items-center justify-center bg-accent/10 text-accent rounded-xl mb-4">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">Toptan Satış</h3>
                <p class="text-fg-muted">Bayiler ve işletmeler için uygun fiyatlarla toptan mobilya tedariği.</p>
              </div>
            </div>
            <div class="swiper-slide">
              <div class="service-card bg-bg-alt p-8 rounded-2xl border border-muted-3">
                <div class="service-icon w-16 h-16 flex items-center justify-center bg-accent/10 text-accent rounded-xl mb-4">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">Perakende Satış</h3>
                <p class="text-fg-muted">Bireysel müşterilerimiz için showroom'umuzda geniş ürün yelpazesi.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Desktop: Grid */}
      <div class="hidden md:grid md:grid-cols-3 gap-8">
        <div class="service-card bg-bg-alt p-8 rounded-2xl border border-muted-3 hover:border-accent transition-colors duration-300">
          <div class="service-icon w-16 h-16 flex items-center justify-center bg-accent/10 text-accent rounded-xl mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">İmalat</h3>
          <p class="text-fg-muted">Kendi atölyemizde özenle üretilen, kaliteli malzemelerle hazırlanan mobilyalar.</p>
        </div>
        <div class="service-card bg-bg-alt p-8 rounded-2xl border border-muted-3 hover:border-accent transition-colors duration-300">
          <div class="service-icon w-16 h-16 flex items-center justify-center bg-accent/10 text-accent rounded-xl mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Toptan Satış</h3>
          <p class="text-fg-muted">Bayiler ve işletmeler için uygun fiyatlarla toptan mobilya tedariği.</p>
        </div>
        <div class="service-card bg-bg-alt p-8 rounded-2xl border border-muted-3 hover:border-accent transition-colors duration-300">
          <div class="service-icon w-16 h-16 flex items-center justify-center bg-accent/10 text-accent rounded-xl mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Perakende Satış</h3>
          <p class="text-fg-muted">Bireysel müşterilerimiz için showroom'umuzda geniş ürün yelpazesi.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tanıtım Bölümü -->
  {bolumGorselleri.length > 0 && (
    <section class="craftsmanship-section py-20 bg-bg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="craftsmanship-header text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            {anasayfaAyarlari?.bolumBaslik || "Ustalığın İzinde"}
          </h2>
          {(anasayfaAyarlari?.bolumAciklama) && (
            <p class="text-fg-muted max-w-2xl mx-auto">
              {anasayfaAyarlari.bolumAciklama}
            </p>
          )}
        </div>

        <div class="accordion-gallery flex flex-col md:flex-row gap-2 md:gap-3 h-auto md:h-[450px] lg:h-[500px] overflow-hidden rounded-2xl">
          {bolumGorselleri.map((item, idx) => (
            <div
              class={`accordion-panel relative cursor-pointer overflow-hidden rounded-xl transition-all duration-700 ease-[cubic-bezier(0.65,0,0.35,1)] ${idx === 0 ? 'is-active' : ''}`}
              data-panel-idx={idx}
            >
              <img
                src={getStrapiImageUrl(item.gorsel, "large")}
                alt={item.etiket || `Görsel ${idx + 1}`}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/20 transition-opacity duration-500 panel-overlay"></div>
              {item.etiket && (
                <div class="panel-label absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/70 to-transparent p-4 md:p-6 transition-opacity duration-500">
                  <span class="text-white font-semibold text-sm md:text-lg whitespace-nowrap">{item.etiket}</span>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Products Section -->
  {
    featuredProducts.length > 0 && (
      <section class="products-section py-20 bg-bg-alt">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="products-header flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-12">
            <div>
              <h2 class="text-3xl md:text-4xl font-bold mb-2">
                Öne Çıkan Ürünler
              </h2>
              <p class="text-fg-muted">En beğenilen oturma gruplarımız</p>
            </div>
            <a
              href="/oturma-gruplari"
              class="inline-flex items-center gap-2 px-6 py-3 border-2 border-fg text-fg font-semibold rounded-lg hover:bg-fg hover:text-bg transition-all"
            >
              Tümünü Gör
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>

          {/* Mobile: Swiper, Desktop: Grid */}
          <div class="featured-swiper-container block lg:hidden">
            <div class="swiper featured-swiper">
              <div class="swiper-wrapper">
                {featuredProducts.map((product) => (
                  <div class="swiper-slide">
                    <a
                      href={`/oturma-gruplari/${product.slug}`}
                      class="product-card block p-4 bg-bg rounded-2xl border border-muted-3 hover:border-accent transition-colors duration-300 group"
                    >
                      <div class="aspect-4/3 rounded-xl overflow-hidden bg-muted-3 mb-4">
                        {product.anaGorsel ? (
                          <img
                            src={getStrapiImageUrl(product.anaGorsel, "medium")}
                            alt={product.baslik}
                            class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-110"
                            loading="lazy"
                          />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-fg-muted">
                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                          </div>
                        )}
                      </div>
                      <h3 class="font-semibold text-lg group-hover:text-accent transition-colors">
                        {product.baslik}
                      </h3>
                      {blocksToSummary(product.detayliAciklama) && (
                        <p class="text-sm text-fg-muted mt-1 line-clamp-2">
                          {blocksToSummary(product.detayliAciklama)}
                        </p>
                      )}
                    </a>
                  </div>
                ))}
              </div>
              <div class="featured-pagination flex justify-center mt-6"></div>
            </div>
          </div>

          {/* Desktop Grid */}
          <div class="hidden lg:grid lg:grid-cols-4 gap-6">
            {featuredProducts.map((product) => (
              <a
                href={`/oturma-gruplari/${product.slug}`}
                class="product-card block p-4 bg-bg rounded-2xl border border-muted-3 hover:border-accent transition-colors duration-300 group"
              >
                <div class="aspect-4/3 rounded-xl overflow-hidden bg-muted-3 mb-4">
                  {product.anaGorsel ? (
                    <img
                      src={getStrapiImageUrl(product.anaGorsel, "medium")}
                      alt={product.baslik}
                      class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-110"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-fg-muted">
                      <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                </div>
                <h3 class="font-semibold text-lg group-hover:text-accent transition-colors">
                  {product.baslik}
                </h3>
                {blocksToSummary(product.detayliAciklama) && (
                  <p class="text-sm text-fg-muted mt-1 line-clamp-2">
                    {blocksToSummary(product.detayliAciklama)}
                  </p>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- SEO Text Block -->
  <section class="py-12 border-t border-muted-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-semibold mb-3 text-fg">Eroll Mobilya Elazığ - Kaliteli Mobilya İmalatı</h2>
      <p class="text-sm text-fg-muted/70 leading-relaxed mb-3">
        Eroll Mobilya, Elazığ'da mobilya imalatı alanında uzun yıllardır hizmet vermektedir. Oturma grubu, koltuk takımı ve salon takımı üretiminde kaliteyi ön planda tutan firmamız, hem toptan hem perakende satış ile müşterilerine ulaşmaktadır. Modern oturma grubu modellerimiz ve özel tasarım mobilyalarımızla evinize değer katıyoruz.
      </p>
      <p class="text-sm text-fg-muted/70 leading-relaxed">
        Köşe koltuk, modern koltuk modelleri ve özel sipariş mobilya ihtiyaçlarınız için Elazığ'ın güvenilir mobilya firmasını tercih edin. Eroll Mobilya & Koltuk olarak, her bütçeye uygun kaliteli ürünler sunuyor, toptan mobilya tedariğiyle bayilerimize de hizmet veriyoruz.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  import { animate, stagger, inView } from "motion";
  import Swiper from "swiper";
  import { Pagination } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  // Services Swiper (mobile only)
  const servicesSwiperEl = document.querySelector(".services-swiper");
  if (servicesSwiperEl) {
    new Swiper(".services-swiper", {
      modules: [Pagination],
      slidesPerView: 1.25,
      spaceBetween: 12,
      pagination: {
        el: ".services-pagination",
        clickable: true,
      },
    });
  }

  // Featured Products Swiper (mobile only)
  const featuredSwiperEl = document.querySelector(".featured-swiper");
  if (featuredSwiperEl) {
    new Swiper(".featured-swiper", {
      modules: [Pagination],
      slidesPerView: 1.15,
      spaceBetween: 16,
      pagination: {
        el: ".featured-pagination",
        clickable: true,
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
      },
    });
  }

  // Accordion Gallery
  const accordionGallery = document.querySelector(".accordion-gallery");
  if (accordionGallery) {
    const panels = accordionGallery.querySelectorAll<HTMLElement>(".accordion-panel");
    let activeIndex = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;
    let isInView = false;
    let isHovered = false;

    function setActive(idx: number) {
      activeIndex = idx;
      panels.forEach((p, i) => {
        if (i === idx) {
          p.classList.add("is-active");
        } else {
          p.classList.remove("is-active");
        }
      });
    }

    // Click to select
    panels.forEach((panel, i) => {
      panel.addEventListener("click", () => {
        setActive(i);
        resetTimer();
      });
    });

    function advance() {
      setActive((activeIndex + 1) % panels.length);
    }

    function startTimer() {
      if (autoTimer) return;
      autoTimer = setInterval(advance, 2500);
    }

    function stopTimer() {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    function resetTimer() {
      stopTimer();
      if (isInView && !isHovered) startTimer();
    }

    // Pause on hover
    accordionGallery.addEventListener("mouseenter", () => { isHovered = true; stopTimer(); });
    accordionGallery.addEventListener("mouseleave", () => { isHovered = false; if (isInView) startTimer(); });

    // Start autoplay only when in view
    const viewObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        isInView = entry.isIntersecting;
        if (isInView && !isHovered) {
          startTimer();
        } else {
          stopTimer();
        }
      });
    }, { threshold: 0.3 });

    viewObserver.observe(accordionGallery);
  }

  // Hero Gallery - smooth pause/resume on hover
  const heroGallery = document.querySelector(".hero-gallery");
  if (heroGallery) {
    const columns = heroGallery.querySelectorAll<HTMLElement>(".animate-scroll-vertical");
    const animations: Animation[] = [];

    // Grab the running CSS animations from each column
    columns.forEach((col) => {
      const anims = col.getAnimations();
      animations.push(...anims);
    });

    let rafId: number | null = null;

    function smoothRate(target: number, duration: number) {
      if (rafId) cancelAnimationFrame(rafId);
      if (animations.length === 0) return;

      const startRate = animations[0].playbackRate;
      const startTime = performance.now();

      function step(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // ease in-out
        const eased = progress < 0.5
          ? 2 * progress * progress
          : 1 - Math.pow(-2 * progress + 2, 2) / 2;
        const rate = startRate + (target - startRate) * eased;
        animations.forEach((a) => { a.playbackRate = rate; });
        if (progress < 1) {
          rafId = requestAnimationFrame(step);
        }
      }

      rafId = requestAnimationFrame(step);
    }

    heroGallery.addEventListener("mouseenter", () => smoothRate(0, 800));
    heroGallery.addEventListener("mouseleave", () => smoothRate(1, 600));
  }

  // Hero Section Animations
  const heroContent = document.querySelector(".hero-content");
  const heroBadge = document.querySelector(".hero-badge");

  if (heroContent) {
    animate(
      heroContent,
      { opacity: [0, 1], y: [40, 0] },
      { duration: 0.8, ease: [0.25, 0.46, 0.45, 0.94] }
    );
  }

  if (heroBadge) {
    animate(
      heroBadge,
      { opacity: [0, 1], scale: [0.8, 1] },
      { duration: 0.6, delay: 0.2, ease: "easeOut" }
    );
  }

  // Services Section - Staggered card animations
  inView(
    ".services-section",
    (info) => {
      const target = info.target || info;
      const serviceCards = target.querySelectorAll(".service-card");
      const servicesTitle = target.querySelector(".services-title");

      if (servicesTitle) {
        animate(
          servicesTitle,
          { opacity: [0, 1], y: [30, 0] },
          { duration: 0.8, ease: "easeOut" }
        );
      }

      if (serviceCards.length > 0) {
        animate(
          serviceCards,
          {
            opacity: [0, 1],
            y: [50, 0],
            scale: [0.95, 1],
          },
          {
            duration: 0.9,
            delay: stagger(0.2, { startDelay: 0.2 }),
            ease: [0.22, 1, 0.36, 1],
          }
        );
      }
    },
    { margin: "-200px" }
  );

  // Craftsmanship Section - Header reveal
  inView(
    ".craftsmanship-section",
    (info) => {
      const target = info.target || info;
      const header = target.querySelector(".craftsmanship-header");

      if (header) {
        animate(
          header,
          { opacity: [0, 1], y: [30, 0] },
          { duration: 0.8, ease: "easeOut" }
        );
      }
    },
    { amount: 0.15 }
  );

  // Featured Products Section - Scale and fade animations
  inView(
    ".products-section",
    () => {
      const productsHeader = document.querySelector(".products-header");
      const productCards = document.querySelectorAll(".product-card");

      if (productsHeader) {
        animate(
          productsHeader,
          { opacity: [0, 1], y: [30, 0] },
          { duration: 0.6, ease: "easeOut" }
        );
      }

      if (productCards.length > 0) {
        animate(
          productCards,
          { opacity: [0, 1], y: [40, 0], scale: [0.92, 1] },
          { duration: 0.7, delay: stagger(0.1), ease: [0.34, 1.56, 0.64, 1] }
        );
      }
    },
    { amount: 0.15 }
  );

  // Hover animations for interactive elements
  const interactiveCards = document.querySelectorAll(
    ".service-card, .product-card"
  );

  interactiveCards.forEach((card) => {
    card.addEventListener("mouseenter", () => {
      animate(
        card,
        { scale: 1.02, y: -5, boxShadow: "0 10px 30px rgba(0,0,0,0.1)" },
        { duration: 0.4, ease: [0.22, 1, 0.36, 1] }
      );
    });

    card.addEventListener("mouseleave", () => {
      animate(
        card,
        { scale: 1, y: 0, boxShadow: "0 0 0 rgba(0,0,0,0)" },
        { duration: 0.4, ease: [0.22, 1, 0.36, 1] }
      );
    });
  });

  // Word Rotator Animation - Fixed with setTimeout chaining
  const rotator = document.querySelector(".word-rotator") as HTMLElement;
  if (rotator) {
    const wordCount = 7; // Number of unique words
    let currentIndex = 0;

    const rotateWord = () => {
      currentIndex++;
      const totalItems = wordCount + 1; // Including duplicate
      const percentage = -1 * (currentIndex * (100 / totalItems));

      const animation = animate(
        rotator,
        { transform: `translateY(${percentage}%)` },
        { duration: 0.5, ease: [0.22, 1, 0.36, 1] }
      );

      animation.finished.then(() => {
        if (currentIndex === wordCount) {
          currentIndex = 0;
          rotator.style.transform = "translateY(0%)";
        }
        setTimeout(rotateWord, 2500);
      });
    };

    setTimeout(rotateWord, 1000);
  }
</script>

<style is:global>
  /* Initial hidden states for Motion animations */
  .hero-content,
  .services-title,
  .service-card,
  .craftsmanship-header,
  .products-header,
  .product-card,
  {
    opacity: 0;
  }

  @keyframes scroll-vertical {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }

  .animate-scroll-vertical {
    animation: scroll-vertical 45s linear infinite;
    animation-play-state: running;
  }

  /* Mobile: hero overlay always visible */
  @media (max-width: 767px) {
    .hero-overlay {
      opacity: 1 !important;
    }
  }

  /* Services Swiper - equal height slides */
  .services-swiper .swiper-slide {
    height: 260px;
  }

  .services-swiper .swiper-slide .service-card {
    height: 100%;
  }

  /* Featured Swiper pagination */
  .featured-pagination .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: var(--color-muted-2);
    opacity: 1;
  }

  .featured-pagination .swiper-pagination-bullet-active {
    background: var(--color-accent);
    width: 24px;
    border-radius: 4px;
  }

  /* Accordion Gallery - Desktop (horizontal) */
  @media (min-width: 768px) {
    .accordion-panel {
      flex: 0 0 60px;
      min-width: 60px;
    }

    .accordion-panel.is-active {
      flex: 1 1 0%;
    }
  }

  /* Accordion Gallery - Mobile (vertical) */
  @media (max-width: 767px) {
    .accordion-panel {
      flex: 0 0 50px;
      min-height: 50px;
      height: 50px;
    }

    .accordion-panel.is-active {
      flex: 1 1 0%;
      height: auto;
      min-height: 250px;
    }

    .accordion-gallery {
      height: 500px !important;
    }
  }

  .accordion-panel:not(.is-active) .panel-overlay {
    opacity: 1;
    background: rgba(0, 0, 0, 0.55);
  }

  .accordion-panel.is-active .panel-overlay {
    opacity: 0;
  }

  .accordion-panel:not(.is-active) .panel-label {
    opacity: 0;
  }

  .accordion-panel.is-active .panel-label {
    opacity: 1;
  }
</style>
